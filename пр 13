#include <iostream>
#include <clocale>
#include <cstdlib>
using namespace std;

int main() {
    setlocale(LC_ALL, "Russian");

    int figure;
    while (true) {
        // Главное меню
        cout << "[ + ] Программа - \"Геометрические фигуры\"\n\n";
        cout << "[ 1 ] Линия\n";
        cout << "[ 2 ] Квадрат\n";
        cout << "[ 3 ] Выход\n\n";

        cout << "[ + ] Выберите фигуру: ";
        cin >> figure;

        if (figure == 3) {
            cout << "[ + ] Выход из программы.\n";
            break;
        }

        switch (figure) {
            case 1: { // Линия
                system("cls");
                int type, length;
                char texture;

                cout << "[ + ] Фигура: \"Линия\"\n\n";
                cout << "[ 1 ] Горизонтальная\n";
                cout << "[ 2 ] Вертикальная\n\n";

                cout << "[ + ] Выберите тип: ";
                cin >> type;

                cout << "[ + ] Длина линии: ";
                cin >> length;

                cout << "[ + ] Текстура линии: ";
                cin >> texture;

                cout << "\n[ + ] Результат:\n";

                if (type == 1) { // горизонтальная
                    for (int i = 0; i < length; i++) {
                        cout << texture << "  ";
                    }
                    cout << endl;
                } else if (type == 2) { // вертикальная
                    for (int i = 0; i < length; i++) {
                        cout << texture << endl;
                    }
                } else {
                    cout << "[ - ] Неверный тип линии!\n";
                }

                cout << "\n[ + ] Нажмите Enter для возврата в меню...";
                cin.ignore();
                cin.get();
                system("cls");
                break;
            }

            case 2: { // Квадрат
                system("cls");
                int type, size;
                char texture;

                cout << "[ + ] Фигура: \"Квадрат\"\n\n";
                cout << "[ 1 ] Заполненный\n";
                cout << "[ 2 ] Пустой\n\n";

                cout << "[ + ] Выберите тип: ";
                cin >> type;

                cout << "[ + ] Размер: ";
                cin >> size;

                cout << "[ + ] Текстура: ";
                cin >> texture;

                cout << "\n[ + ] Результат:\n\n";

                for (int i = 0; i < size; i++) {
                    for (int j = 0; j < size; j++) {
                        if (type == 1) { // заполненный
                            cout << texture << "   ";
                        } else if (type == 2) { // пустой
                            if (i == 0 || i == size-1 || j == 0 || j == size-1)
                                cout << texture << "   ";
                            else
                                cout << "    ";
                        } else {
                            cout << "[ - ] Неверный тип квадрата!\n";
                            break;
                        }
                    }
                    cout << endl;
                }

                cout << "\n[ + ] Нажмите Enter для возврата в меню...";
                cin.ignore();
                cin.get();
                system("cls");
                break;
            }

            default:
                cout << "[ - ] Неверный пункт меню!\n";
                system("cls");
                break;
        }
    }

    return 0;
}
