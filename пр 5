#include <iostream>
#include <locale>

using namespace std;

int main() {
    setlocale(LC_ALL, "Russian");

    double a, b;
    char op;

    cout << "Выберите операцию (+, -, *, /, %): ";
    cin >> op;

    cout << "Введите первое число: ";
    cin >> a;

    cout << "Введите второе число: ";
    cin >> b;

    if (op == '+') {
        cout << "[ + ] Результат: " << a << " + " << b << " = " << a + b << endl;
    }
    else if (op == '-') {
        cout << "[ - ] Результат: " << a << " - " << b << " = " << a - b << endl;
    }
    else if (op == '*') {
        cout << "[ * ] Результат: " << a << " * " << b << " = " << a * b << endl;
    }
    else if (op == '/') {
        if (b == 0) {
            cout << "Ошибка: деление на 0 запрещено!" << endl;
        }
        else {
            cout << "[ / ] Результат: " << a << " / " << b << " = " << a / b << endl;
        }
    }
    else if (op == '%') {
        if ((int)b == 0) {
            cout << "Ошибка: деление на 0 запрещено!" << endl;
        }
        else {
            cout << "[ % ] Результат: " << (int)a << " % " << (int)b << " = " << (int)a % (int)b << endl;
        }
    }
    else {
        cout << "Неизвестная операция!" << endl;
    }

    return 0;
}
