#include <iostream>
#include <string>
#include <windows.h>
#include <locale.h>
#include <ctime>

using namespace std;

/* ---------- РУССКАЯ КОДИРОВКА ---------- */
void russian()
{
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);
    setlocale(LC_ALL, "Russian");
}

/* ---------- ЦВЕТ ---------- */
void setColor(int c)
{
    SetConsoleTextAttribute(GetStdHandle(STD_OUTPUT_HANDLE), c);
}

/* ---------- СТРУКТУРА ИГРОКА ---------- */
struct Player
{
    string nick = "Игрок";
    char symbol = 'X';
    int color = 15;

    int wins = 0;
    int loses = 0;
    int draws = 0;
    double points = 0;
};

Player p1, p2, comp;

/* ---------- ПОЛЕ ---------- */
char board[3][3];

void clearBoard()
{
    char n = '1';
    for (int i = 0;i < 3;i++)
        for (int j = 0;j < 3;j++)
            board[i][j] = n++;
}

void drawBoard()
{
    cout << "\n";
    for (int i = 0;i < 3;i++)
    {
        for (int j = 0;j < 3;j++)
        {
            cout << " " << board[i][j] << " ";
            if (j < 2) cout << "|";
        }
        cout << "\n";
        if (i < 2) cout << "---+---+---\n";
    }
}

/* ---------- ПРОВЕРКА ПОБЕДЫ ---------- */
char winner()
{
    for (int i = 0;i < 3;i++)
    {
        if (board[i][0] == board[i][1] && board[i][1] == board[i][2])
            return board[i][0];

        if (board[0][i] == board[1][i] && board[1][i] == board[2][i])
            return board[0][i];
    }

    if (board[0][0] == board[1][1] && board[1][1] == board[2][2])
        return board[0][0];

    if (board[0][2] == board[1][1] && board[1][1] == board[2][0])
        return board[0][2];

    return ' ';
}

bool draw()
{
    for (int i = 0;i < 3;i++)
        for (int j = 0;j < 3;j++)
            if (board[i][j] >= '1' && board[i][j] <= '9')
                return false;
    return true;
}

bool move(int cell, char sym)
{
    int r = (cell - 1) / 3;
    int c = (cell - 1) % 3;

    if (board[r][c] != 'X' && board[r][c] != 'O')
    {
        board[r][c] = sym;
        return true;
    }
    return false;
}

/* ---------- ОЧКИ ---------- */
void win(Player& p) { p.wins++; p.points += 5; }
void lose(Player& p) { p.loses++; p.points -= 6; }
void drawScore(Player& p) { p.draws++; p.points -= 1.2; }

/* ---------- ИГРА 2 ИГРОКА ---------- */
void twoPlayers()
{
    clearBoard();
    int cell;
    char w = ' ';

    while (true)
    {
        drawBoard();
        cout << p1.nick << " ход: ";
        cin >> cell;
        if (!move(cell, p1.symbol)) continue;

        w = winner();
        if (w != ' ' || draw()) break;

        drawBoard();
        cout << p2.nick << " ход: ";
        cin >> cell;
        if (!move(cell, p2.symbol)) continue;

        w = winner();
        if (w != ' ' || draw()) break;
    }

    drawBoard();

    if (w == p1.symbol) { cout << "Победил " << p1.nick << "\n"; win(p1); lose(p2); }
    else if (w == p2.symbol) { cout << "Победил " << p2.nick << "\n"; win(p2); lose(p1); }
    else { cout << "Ничья!\n"; drawScore(p1); drawScore(p2); }
}

/* ---------- ИГРА С ПК ---------- */
void singleGame()
{
    clearBoard();
    srand(time(0));
    int cell;
    char w = ' ';

    while (true)
    {
        drawBoard();
        cout << "Ваш ход: ";
        cin >> cell;
        if (!move(cell, p1.symbol)) continue;

        w = winner();
        if (w != ' ' || draw()) break;

        int c;
        do { c = rand() % 9 + 1; } while (!move(c, comp.symbol));

        cout << "Компьютер сходил!\n";

        w = winner();
        if (w != ' ' || draw()) break;
    }

    drawBoard();

    if (w == p1.symbol) { cout << "Вы победили!\n"; win(p1); lose(comp); }
    else if (w == comp.symbol) { cout << "Компьютер победил!\n"; win(comp); lose(p1); }
    else { cout << "Ничья!\n"; drawScore(p1); drawScore(comp); }
}

/* ---------- СТАТИСТИКА ---------- */
void stats()
{
    cout << "\n=== СТАТИСТИКА ===\n";

    cout << p1.nick << " Победы:" << p1.wins
        << " Поражения:" << p1.loses
        << " Ничьи:" << p1.draws
        << " Очки:" << p1.points << "\n";

    cout << p2.nick << " Победы:" << p2.wins
        << " Поражения:" << p2.loses
        << " Ничьи:" << p2.draws
        << " Очки:" << p2.points << "\n";

    cout << "Компьютер Победы:" << comp.wins
        << " Поражения:" << comp.loses
        << " Ничьи:" << comp.draws
        << " Очки:" << comp.points << "\n";

    system("pause");
}

/* ---------- НАСТРОЙКИ ---------- */
void settings()
{
    int ch;

    while (true)
    {
        system("cls");
        cout << "=== НАСТРОЙКИ ===\n";
        cout << "1. Игрок 1\n";
        cout << "2. Игрок 2\n";
        cout << "3. Назад\n";
        cin >> ch;

        if (ch == 3) return;

        Player* p = (ch == 1) ? &p1 : &p2;

        cout << "Введите ник: ";
        cin >> p->nick;

        cout << "Символ: ";
        cin >> p->symbol;

        cout << "Цвет (1-15): ";
        cin >> p->color;
    }
}

/* ---------- НАЧАТЬ ---------- */
void startGame()
{
    int m;
    cout << "1. Одиночная игра\n";
    cout << "2. Два игрока\n";
    cout << "3. Назад\n";
    cin >> m;

    switch (m)
    {
    case 1: singleGame(); break;
    case 2: twoPlayers(); break;
    default: return;
    }

    system("pause");
}

/* ---------- МЕНЮ ---------- */
void menu()
{
    int ch;

    while (true)
    {
        system("cls");
        setColor(11);
        cout << "=== КРЕСТИКИ НОЛИКИ ===\n\n";
        setColor(15);

        cout << "1. Начать игру\n";
        cout << "2. Статистика\n";
        cout << "3. Настройки\n";
        cout << "4. Выйти\n";

        cin >> ch;

        switch (ch)
        {
        case 1: startGame(); break;
        case 2: stats(); break;
        case 3: settings(); break;
        case 4: exit(0);
        }
    }
}

/* ---------- MAIN ---------- */
int main()
{
    russian();

    comp.symbol = 'O';
    comp.nick = "Компьютер";

    menu();
}
