#include <iostream>
using namespace std;

int main() {

    int choice;

    cout << "[ - ] Программа \"Времена года\"\n\n";

    cout << "[ 1 ] Лето\n";
    cout << "[ 2 ] Осень\n";
    cout << "[ 3 ] Зима\n";
    cout << "[ 4 ] Весна\n\n";

    cout << "[ - ] Введите значение: ";
    cin >> choice;

    if (choice == 1) {
        cout << "[ - ] Сейчас лето, можно гулять, отдыхать и наслаждаться теплой погодой." << endl;
    }
    else if (choice == 2) {
        cout << "[ - ] Сейчас осень, следует одеться тепло и взять с собой зонт." << endl;
    }
    else if (choice == 3) {
        cout << "[ - ] Сейчас зима, на улице холодно, не забудьте теплую одежду." << endl;
    }
    else if (choice == 4) {
        cout << "[ - ] Сейчас весна, природа просыпается и становится теплее." << endl;
    }
    else {
        cout << "[ - ] Такого времени года нет." << endl;
    }

    return 0;
}
