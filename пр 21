// Функция для рисования рекурсивного квадрата
void recursiveSquare(int size, char texture, int row = 0, int col = 0) {
    int mid = size / 2;

    for (int i = 0; i < size; i++) {
        for (int j = 0; j < size; j++) {
            // Рисуем границы внешнего квадрата
            if (i == 0 || i == size - 1 || j == 0 || j == size - 1) {
                cout << texture << "   ";
            }
            // Рисуем вложенные квадраты (примерно по образцу)
            else if ((i == 2 && j >= 2 && j <= size - 3) ||
                     (i == size - 3 && j >= 2 && j <= size - 3) ||
                     (j == 2 && i >= 2 && i <= size - 3) ||
                     (j == size - 3 && i >= 2 && i <= size - 3)) {
                cout << texture << "   ";
            }
            else {
                cout << ".   ";
            }
        }
        cout << endl;
    }
}

